[Unit]
Description=ABAC Flask App
After=network.target

[Service]
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/apps/ABAC_Sak
EnvironmentFile=/home/ubuntu/apps/ABAC_Sak/.env
ExecStart=/home/ubuntu/apps/ABAC_Sak/.venv/bin/gunicorn \
    --bind 0.0.0.0:5001 \
    --workers 2 \
    --timeout 120 \
    app:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
